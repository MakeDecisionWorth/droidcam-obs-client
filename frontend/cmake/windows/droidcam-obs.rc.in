IDI_ICON1 ICON DISCARDABLE "cmake/windows/droidcam-obs.ico"

1 VERSIONINFO
FILEVERSION ${OBS_VERSION_MAJOR},${OBS_VERSION_MINOR},${OBS_VERSION_PATCH},0
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName", "DEV47APPS & MakeDecisionWorth"
      VALUE "FileDescription", "DroidCam Client"
      VALUE "FileVersion", "${OBS_VERSION_CANONICAL}"
      VALUE "InternalName", "droidcam-obs"
      VALUE "OriginalFilename", "obs"
      VALUE "ProductName", "DroidCam"
      VALUE "ProductVersion", "8"
      VALUE "Comments", "Free and open source software for video recording and live streaming"
      VALUE "LegalCopyright", "${OBS_LEGAL_COPYRIGHT} & 2022, DEV47APPS & 2025, MakeDecisionWorth"
    END
  END

  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 0x04B0
  END
END
